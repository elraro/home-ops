{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "Auto-merge container for digest, minor and patch trusted containers",
      "matchDatasources": ["docker"],
      "automerge": true,
      "automergeType": "branch",
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackagePatterns": ["ghcr.io/bjw-s", "ghcr.io/onedr0p", "ghcr.io/home-operations", "ghcr.io/starosdev", "ghcr.io/stirling-tools", "registry.suse.com/suse/"]
    },
    {
      "description": "Auto-merge Helm chart patch/minor updates",
      "matchManagers": ["helmv3"],
      "automerge": true,
      "automergeType": "branch",
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "description": "Auto-merge GitHub Actions for minor and patch",
      "matchManagers": ["github-actions"],
      "automerge": true,
      "automergeType": "branch",
      "matchUpdateTypes": ["digest", "minor", "patch"]
    }
  ]
}
